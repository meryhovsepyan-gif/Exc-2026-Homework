#include <iostream>
using namespace std;
long long factorial(long long n){
    if(n <= 1){
        return 1;
    }
    return n * factorial(n - 1);
}
int main()
{
    long long target;
    cin >> target;
    
    if (target == 1) {
        cout << "1 or 0"; 
        return 0;
    }
    long long index = 0;
    while(true){
        long long value = factorial(index);
        if(value == target){
            cout << index;
            break;
        }
        if(value > target){
            cout << -1;
            break;
        }
        index++;
    }
    return 0;
}
