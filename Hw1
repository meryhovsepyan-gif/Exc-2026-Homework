#include <iostream>
using namespace std;
int main()
{
    bool hasDuplicate = false;
    int n;
    cin>> n;
    int num[n];
    for(int i = 0; i < n; i++){
        cin >> num[i];
    }
    for(int i = 0; i < n; i ++){
        for(int j = i + 1; j < n; j++){
            if(num[i] == num[j]){
                hasDuplicate = true;
                break;
            }
        }
    }
    if(hasDuplicate) {
        cout << "true" << endl;
    } else {
        cout << "false" << endl;
    }
}