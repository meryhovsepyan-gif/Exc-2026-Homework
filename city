string to_low(string s) {
    for (int i = 0; i < s.length(); i++) {
        s[i] = tolower(s[i]);
    }
    return s;
}

string remove_spaces(string s) {
    string res = "";
    for (int i = 0; i < s.length(); i++) {
        if (s[i] != ' ' && s[i] != '\r' && s[i] != '\n') res += s[i];
    }
    return res;
}

