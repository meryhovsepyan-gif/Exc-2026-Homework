#include <iostream>
#include <string>
#include <algorithm>
#include <unordered_map>
using namespace std;

bool areAnagrams(string s1, string s2) {
	if (s1.length() != s2.length()) {
		return false;
}
	sort(s1.begin(), s1.end());
	sort(s2.begin(), s2.end());
	return s1 == s2;
}

int main() {
	int n;
	cin >> n;
	string strs[n];

	for (int i = 0; i < n; i++) {
		cin >> strs[i];
	}
	unordered_map <string, bool> seen;
	for (int i = 0; i < n; i++) {
		if(seen[strs[i]]) {
			continue;
		}
		cout << "[ " << strs[i] << " ";
		seen[strs[i]] = true;

		for (int j = i + 1; j < n; j++) {
			if (!seen[strs[j]] && areAnagrams(strs[i], strs[j])) {
				cout << strs[j] << " ";
				seen[strs[j]] = true;
			}
		}
		cout << "]" << endl;
	}
}