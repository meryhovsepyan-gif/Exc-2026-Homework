#include <iostream>
#include <algorithm>
#include <string>
using namespace std;
string subtract(string a, string b) {
    //checking if a < b just swap them
    bool negative = false;
    if (a.length() < b.length() || (a.length() == b.length() && a < b)) {
        swap(a, b);
        negative = true;
    }
	int i = a.length() - 1;
	int j = b.length() - 1;
	int carry = 0;
	string result;
		while (i >= 0) {
		    /*"take a digit from 'a', convert it to a char,
		    and do the same for 'b' as long as there are digits remaining. */
			int val1 = a[i] - '0';
			int val2 = (j >= 0) ? (b[j] - '0') : 0;
			
			int sub = val1 - val2 - carry;
			/*If a[i] < b[j] (for example, 32 - 8, where 2 < 8),
			we add 10 to the result to obtain the digit for the subtraction,
			and set carry = 1. This is because we have borrowed from the next
			digit (in our case, the 3), which changes the 3 to a 2 in the top
			row by -1-ing
			*/
			if (sub < 0) {
				sub += 10;
				carry = 1;
			} else {
				carry = 0;
			}
			result.push_back(sub + '0');
			i--;
			j--;
		}
	//Getting rid of extra zeros
	while (result.length() > 1 && result.back() == '0') {
		result.pop_back();
	}
	reverse(result.begin(), result.end());
	/*If b was > a, the result should be negative;
	therefore, we add a '-' sign at the very beginning.*/
	return negative ? '-' + result : result;}

int main() {

	cout<<  subtract("120", "420");
	return 0;
}