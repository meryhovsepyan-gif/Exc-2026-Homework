#include <iostream>
#include <stack>
using namespace std;
int main()
{
    string s;
    cin >> s;
    stack<char> a;
    for (int i = 0; i < s.length(); i++) {
        if(s[i] == '('){
            a.push(')');
        }
        else if(s[i] == '['){
            a.push(']');
        }
        else if(s[i] == '{'){
            a.push('}');
        }
        else if (s[i] == ')' || s[i] == ']' || s[i] == '}') {
            if (a.empty() || a.top() != s[i]) {
                cout << "False";
                return 0;
            }
            a.pop();
        }
    }
    cout << "True";
    return 0;
}