#include <iostream>
#include <unordered_map>
#include <string>

using namespace std;

int main() {
    string line = "aaaaabbsshhdjska";
    // Create a map to store each character and its frequency
    unordered_map<char, int> count;
    
    // Iterate through the string and increment the count for each character found
    for(char c : line){
        count[c]++;
    }
    // Loop through the map to display the results
    for(auto i = count.begin(); i != count.end(); i++){
        /* If the character appears more than once,
        print the character followed by the count*/
        if(i->second != 1){
        cout << i->first << i->second << " ";
    }
    // Otherwise, just print the character by itself 
    else{
        cout << i->first << " ";
    }}

    return 0;
}